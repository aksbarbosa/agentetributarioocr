{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/irpf/schemas/extracted_recibo_medico.json",
  "title": "Extração de Recibo Médico",
  "description": "Schema da saída estruturada de extração de um recibo médico.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document_type",
    "source_file",
    "fields"
  ],
  "properties": {
    "document_type": {
      "type": "string",
      "const": "recibo_medico"
    },
    "source_file": {
      "type": "string",
      "minLength": 1
    },
    "fields": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cpf_declarante",
        "nome_declarante",
        "data_nascimento",
        "cpf_cnpj_prestador",
        "nome_prestador",
        "valor_pago",
        "data_pagamento",
        "descricao"
      ],
      "properties": {
        "cpf_declarante": {
          "$ref": "#/$defs/extracted_field"
        },
        "nome_declarante": {
          "$ref": "#/$defs/extracted_field"
        },
        "data_nascimento": {
          "$ref": "#/$defs/extracted_field"
        },
        "cpf_cnpj_prestador": {
          "$ref": "#/$defs/extracted_field"
        },
        "nome_prestador": {
          "$ref": "#/$defs/extracted_field"
        },
        "valor_pago": {
          "$ref": "#/$defs/extracted_field"
        },
        "data_pagamento": {
          "$ref": "#/$defs/extracted_field"
        },
        "descricao": {
          "$ref": "#/$defs/extracted_field"
        }
      }
    }
  },
  "$defs": {
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "extracted_field": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "confidence",
        "source_hint"
      ],
      "properties": {
        "value": {
          "type": [
            "string",
            "number",
            "integer",
            "null"
          ],
          "description": "Valor bruto extraído do documento."
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "source_hint": {
          "type": "string",
          "description": "Indicação textual de onde o campo foi encontrado no documento."
        }
      }
    }
  }
}